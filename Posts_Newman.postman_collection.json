    {
      "name": "Delete Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code indicates successful deletion (200 or 204)', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([",
              "        200,",
              "        204",
              "    ]);",
              "})",
              "",
              "pm.test('Response time is under 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "})",
              "",
              "pm.test('Response body is empty or confirms deletion', function () {",
              "    if (pm.response.code === 204) {",
              "        pm.expect(pm.response.text()).to.be.empty;",
              "    } else {",
              "        const responseText = pm.response.text();",
              "        if (responseText && responseText.trim() !== '') {",
              "            const jsonData = pm.response.json();",
              "            pm.expect(jsonData).to.be.an('object');",
              "        }",
              "    }",
              "})"
            ]
          }
        }
