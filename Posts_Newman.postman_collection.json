    {
      "name": "Comments on a post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "pm.test('Response time is under 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "})",
              "",
              "pm.test('Content-Type is application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "})",
              "",
              "pm.test('Response body is valid JSON', function () {",
              "    pm.response.to.be.json;",
              "})",
              "",
              "pm.test('Post ID is 1', function () {",
              "    const jsonData = pm.response.json();",
              "    if (Array.isArray(jsonData)) {",
              "        jsonData.forEach(function (comment) {",
              "            pm.expect(comment).to.have.property('postId').that.eql(1);",
              "        });",
              "    } else {",
              "        pm.expect(jsonData).to.have.property('id').that.eql(1);",
              "    }",
              "})",
              "",
              "pm.test('Response has required fields', function () {",
              "    const jsonData = pm.response.json();",
              "    if (Array.isArray(jsonData)) {",
              "        jsonData.forEach(function (comment) {",
              "            pm.expect(comment).to.have.property('id');",
              "            pm.expect(comment).to.have.property('body');",
              "        });",
              "    } else {",
              "        pm.expect(jsonData).to.have.property('id');",
              "        pm.expect(jsonData).to.have.property('body');",
              "    }",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
